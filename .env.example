# ── API Gateway ──────────────────────────────────────────────────────────────
ORDER_SERVICE_URL=http://localhost:8001
MENU_SERVICE_URL=http://localhost:8002
BILLING_SERVICE_URL=http://localhost:8003
TABLE_SERVICE_URL=http://localhost:8004
STORE_SERVICE_URL=http://localhost:8005
DELIVERY_SERVICE_URL=http://localhost:8006
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Domain Services (set per service) ────────────────────────────────────────
SERVICE_NAME=service-name
SERVICE_PORT=8001
DATABASE_URL=sqlite+aiosqlite:///./service.db
